#!/bin/bash

layout=""
capacity=""
capacity_num=""
timedate=""
status=""
brightness=""
volume=""
cpu_temp=""
dns=""
bluetooth=""
low_battery_notified=""
wifi=""
vpn=""
cpu_usage=""
prev_idle=0
prev_total=0
ram_usage=""
top_process=""
top_ram_process=""
power_watts=""

has_cmd() {
    command -v "$1" >/dev/null 2>&1
}

missing() {
    printf 'missing: %s' "$1"
}

is_number() {
    [[ "$1" =~ ^[0-9]+$ ]]
}

missing_color() {
    case "$1" in
        missing:*)
            printf ',"color":"#FF0000"'
            ;;
    esac
}

get_layout() {
  layout=""

  if has_cmd xset; then
    kb=$(xset -q 2>/dev/null | grep -oP '\d{8}' | head -1)

    case $kb in
      "00001000")
      layout="ru"
      ;;
      "00000000")
      layout="en"
      ;;
    esac

    [ -n "$layout" ] && return
  fi

  if has_cmd setxkbmap; then
    local active_layout=$(setxkbmap -query 2>/dev/null | awk '/layout:/ {print $2}' | awk -F, '{print $1}')
    case "$active_layout" in
      jaennil_rpd|us|en)
        layout="en"
        ;;
      ru)
        layout="ru"
        ;;
      "")
        layout="unknown"
        ;;
      *)
        layout="$active_layout"
        ;;
    esac
    return
  fi

  layout=$(missing "xset/setxkbmap")
}

battery() {
    local bat=""

    if [ -d /sys/class/power_supply/BAT0 ]; then
        bat="/sys/class/power_supply/BAT0"
    else
        for supply in /sys/class/power_supply/*; do
            [ -d "$supply" ] || continue
            [ "$(cat "$supply/type" 2>/dev/null)" = "Battery" ] || continue
            bat="$supply"
            break
        done
    fi

    if [ -z "$bat" ]; then
        capacity_num=""
        capacity="no battery"
        status=""
        power_watts=""
        return
    fi

    capacity_num="$(cat "$bat/capacity" 2>/dev/null)"
    capacity="${capacity_num}%"
    status="$(cat "$bat/status" 2>/dev/null)"

    # Get power in watts
    if [ -f "$bat/power_now" ]; then
        local power_uw=$(cat "$bat/power_now")
        power_watts=$(awk "BEGIN {printf \"%.1fW\", $power_uw / 1000000}")
    elif [ -f "$bat/current_now" ] && [ -f "$bat/voltage_now" ]; then
        local current_ua=$(cat "$bat/current_now")
        local voltage_uv=$(cat "$bat/voltage_now")
        power_watts=$(awk "BEGIN {printf \"%.1fW\", ($current_ua * $voltage_uv) / 1000000000000}")
    else
        power_watts="N/A"
    fi
}

timedate() {
    timedate=$(LC_ALL=en_US.UTF-8 date +"%A %d-%m-%Y %H:%M:%S")
}

brightness() {
    local bl=$(ls /sys/class/backlight/ | head -1)
    if [ -n "$bl" ]; then
        local cur=$(cat /sys/class/backlight/$bl/brightness)
        local max=$(cat /sys/class/backlight/$bl/max_brightness)
        brightness=$((cur * 100 / max))%
    else
        brightness="N/A"
    fi
}

volume() {
    volume=""

    if has_cmd amixer; then
        volume=$(amixer sget Master 2>/dev/null | awk '/Front Left:/ {print $5 $6; exit}')
        [ -n "$volume" ] && return
    fi

    if has_cmd pactl; then
        local vol=$(pactl get-sink-volume @DEFAULT_SINK@ 2>/dev/null | awk -F/ 'NR==1 {gsub(/[ \t]/, "", $2); print $2}')
        local mute=$(pactl get-sink-mute @DEFAULT_SINK@ 2>/dev/null | awk '{print $2}')

        if [ -n "$vol" ]; then
            if [ "$mute" = "yes" ]; then
                volume="${vol} [off]"
            else
                volume="${vol} [on]"
            fi
            return
        fi
    fi

    volume=$(missing "amixer/pactl")
}

cpu_temp() {
    local zone hwmon temp_file

    for z in /sys/class/thermal/thermal_zone*; do
        if grep -q "x86_pkg_temp\|coretemp\|k10temp" "$z/type" 2>/dev/null; then
            zone="$z"
            break
        fi
    done

    if [ -z "$zone" ]; then
        for hwmon in /sys/class/hwmon/hwmon*; do
            if grep -q "x86_pkg_temp\|coretemp\|k10temp" "$hwmon/name" 2>/dev/null; then
                temp_file=$(find "$hwmon" -maxdepth 1 -name 'temp*_input' | sort | head -n 1)
                if [ -n "$temp_file" ]; then
                    cpu_temp=$(printf "%3d°C" $(($(cat "$temp_file") / 1000)))
                    return
                fi
            fi
        done
    fi

    if [ -n "$zone" ]; then
        cpu_temp=$(printf "%3d°C" $(($(cat "$zone/temp") / 1000)))
    else
        for z in /sys/class/thermal/thermal_zone*; do
            if [ -r "$z/temp" ]; then
                cpu_temp=$(printf "%3d°C" $(($(cat "$z/temp") / 1000)))
                return
            fi
        done
        cpu_temp="N/A"
    fi
}

cpu_usage() {
    local cpu_line=$(head -1 /proc/stat)
    local user=$(echo "$cpu_line" | awk '{print $2}')
    local nice=$(echo "$cpu_line" | awk '{print $3}')
    local system=$(echo "$cpu_line" | awk '{print $4}')
    local idle=$(echo "$cpu_line" | awk '{print $5}')
    local iowait=$(echo "$cpu_line" | awk '{print $6}')
    local irq=$(echo "$cpu_line" | awk '{print $7}')
    local softirq=$(echo "$cpu_line" | awk '{print $8}')

    local total=$((user + nice + system + idle + iowait + irq + softirq))
    local diff_idle=$((idle - prev_idle))
    local diff_total=$((total - prev_total))

    if [ "$diff_total" -gt 0 ]; then
        cpu_usage=$((100 * (diff_total - diff_idle) / diff_total))%
    else
        cpu_usage="0%"
    fi

    prev_idle=$idle
    prev_total=$total
}

ram_usage() {
    local total=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
    local available=$(awk '/MemAvailable/ {print $2}' /proc/meminfo)
    local used=$((total - available))
    ram_usage=$((used * 100 / total))%
}

top_process() {
    top_process=$(top -bn1 -o %CPU | awk 'NR>7 {
        name = substr($12, 1, 8)
        pad = int((8 - length(name)) / 2)
        printf "%*s%-*s %3.0f%%", pad, "", 8 - pad, name, $9
        exit
    }')
}

top_ram_process() {
    top_ram_process=$(top -bn1 -o %MEM | awk 'NR>7 {
        name = substr($12, 1, 8)
        pad = int((8 - length(name)) / 2)
        printf "%*s%-*s %3.0f%%", pad, "", 8 - pad, name, $10
        exit
    }')
}

dns() {
    if has_cmd nmcli; then
        dns=$(nmcli dev show 2>/dev/null | awk '/IP4.DNS/ {print $2}' | tr '\n' ' ' | sed 's/ $//' | sed 's/ /  /g')
    else
        dns=$(missing "nmcli")
    fi
}

wifi() {
    local ssid=""
    local quality=""

    if has_cmd iwgetid; then
        ssid=$(iwgetid -r 2>/dev/null)
    fi

    if [ -n "$ssid" ]; then
        quality=$(awk 'NR==3 {printf "%.0f%%", $3*100/70}' /proc/net/wireless 2>/dev/null)
        wifi="$ssid $quality"
        return
    fi

    if has_cmd nmcli; then
        ssid=$(nmcli -t -f ACTIVE,SSID dev wifi 2>/dev/null | awk -F: '$1 == "yes" {print $2; exit}')
        [ -n "$ssid" ] && quality=$(nmcli -t -f ACTIVE,SIGNAL dev wifi 2>/dev/null | awk -F: '$1 == "yes" {print $2 "%"; exit}')

        if [ -n "$ssid" ]; then
            wifi="$ssid $quality"
            return
        fi

        if nmcli -t -f TYPE,STATE dev status 2>/dev/null | grep -q '^wifi:connected$'; then
            wifi="connected"
            return
        fi
    fi

    if ! has_cmd iwgetid && ! has_cmd nmcli; then
        wifi=$(missing "iwgetid/nmcli")
        return
    fi

    wifi="down"
}

vpn() {
    if ! has_cmd nmcli; then
        vpn=$(missing "nmcli")
    elif nmcli -t -f TYPE,STATE connection show --active 2>/dev/null | grep -q "^vpn:"; then
        vpn="up"
    else
        vpn="down"
    fi
}

bluetooth() {
    if ! has_cmd bluetoothctl; then
        bluetooth=$(missing "bluetoothctl")
        bluetooth_battery=""
        return
    fi

    local devices=$(timeout 1s bluetoothctl devices Connected 2>/dev/null | awk '{print $2}')
    if [ -z "$devices" ]; then
        bluetooth="-"
        bluetooth_battery=""
        return
    fi

    local names=""
    local batteries=""
    for mac in $devices; do
        local name=$(timeout 1s bluetoothctl info "$mac" 2>/dev/null | awk -F': ' '/Name:/ {print $2}')
        [ -z "$name" ] && name="$mac"
        names="${names}${name}, "

        local bat=""
        if has_cmd upower; then
            bat=$(timeout 1s upower -e 2>/dev/null | grep -i "${mac//:/_}" | xargs -r -I{} timeout 1s upower -i {} 2>/dev/null | awk '/percentage:/ {print $2}' | tr -d '%')
        fi
        [ -n "$bat" ] && batteries="${batteries}${bat}% " || batteries="${batteries}N/A "
    done

    bluetooth="${names%, }"
    bluetooth_battery="${batteries% }"
}

json_escape() {
    printf '%s' "$1" | tr -d '\000-\037' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

handle_clicks() {
    while IFS= read -r click_event; do
        case "$click_event" in
            *'"name":"brightness"'*)
                ~/.config/bin/brightness-slider.sh >/dev/null 2>&1 &
                ;;
        esac
    done
}

output_status() {
# Output JSON header for i3bar protocol
echo '{"version":1,"click_events":true}'
echo '['
echo '[]'

while :
do
  get_layout
  battery
  brightness
  timedate
  volume
  cpu_temp
  cpu_usage
  ram_usage
  top_process
  top_ram_process
  dns
  bluetooth
  wifi
  vpn

  top_process=$(json_escape "$top_process")
  top_ram_process=$(json_escape "$top_ram_process")
  dns=$(json_escape "$dns")
  bluetooth=$(json_escape "$bluetooth")
  bluetooth_battery=$(json_escape "$bluetooth_battery")
  wifi=$(json_escape "$wifi")
  volume=$(json_escape "$volume")

  # Low battery notification
  if is_number "$capacity_num" && [ "$capacity_num" -le 20 ] && [ "$status" = "Discharging" ] && [ -z "$low_battery_notified" ]; then
      notify-send -u critical "Low Battery" "Battery at ${capacity_num}%"
      low_battery_notified="1"
  elif { is_number "$capacity_num" && [ "$capacity_num" -gt 20 ]; } || [ "$status" = "Charging" ]; then
      low_battery_notified=""
  fi

  # Battery status color
  if [ "$status" = "Charging" ]; then
      status_color=',"color":"#00FF00"'  # green
  elif [ "$status" = "Discharging" ]; then
      status_color=',"color":"#FFFF00"'  # yellow
  else
      status_color=""
  fi

  # Battery capacity color
  if ! is_number "$capacity_num"; then
      capacity_color=""
  elif [ "$capacity_num" -lt 30 ]; then
      capacity_color=',"color":"#FF0000"'  # red
  elif [ "$capacity_num" -lt 60 ]; then
      capacity_color=',"color":"#FFFF00"'  # yellow
  else
      capacity_color=',"color":"#00FF00"'  # green
  fi

  # CPU temp color
  cpu_temp_num=$(echo "$cpu_temp" | grep -oP '\d+')
  if [ "$cpu_temp_num" -gt 95 ] 2>/dev/null; then
      cpu_color=',"color":"#FF0000"'  # red - hot
  elif [ "$cpu_temp_num" -gt 65 ] 2>/dev/null; then
      cpu_color=',"color":"#FF6600"'  # orange - warm
  else
      cpu_color=',"color":"#00FF00"'  # green - normal
  fi

  wifi_color=$(missing_color "$wifi")
  bluetooth_color=$(missing_color "$bluetooth")
  dns_color=$(missing_color "$dns")

  # Volume color
  if [ -n "$(missing_color "$volume")" ]; then
      volume_color=$(missing_color "$volume")
  elif echo "$volume" | grep -q "\[off\]"; then
      volume_color=',"color":"#00FF00"'  # green - muted
  else
      volume_color=',"color":"#FF6600"'  # orange - on
  fi

  # DNS color (red if stage)
  stage_dns="10.13.245.31"
  if [ -n "$dns_color" ]; then
      dns_suffix=""
  elif [ "$dns" = "$stage_dns" ]; then
      dns_color=',"color":"#FF0000"'
      dns_suffix=" (stage)"
  else
      dns_color=""
      dns_suffix=""
  fi

  # Bluetooth battery color
  bt_bat_num=$(echo "$bluetooth_battery" | grep -oP '^\d+' | head -1)
  if [ -n "$bt_bat_num" ]; then
      if [ "$bt_bat_num" -lt 10 ]; then
          bt_bat_color=',"color":"#FF0000"'  # red
      elif [ "$bt_bat_num" -lt 20 ]; then
          bt_bat_color=',"color":"#FF6600"'  # orange
      elif [ "$bt_bat_num" -lt 40 ]; then
          bt_bat_color=',"color":"#FFFF00"'  # yellow
      else
          bt_bat_color=',"color":"#00FF00"'  # green - good
      fi
  else
      bt_bat_color=""
  fi

  # VPN color
  if [ -n "$(missing_color "$vpn")" ]; then
      vpn_color=$(missing_color "$vpn")
  elif [ "$vpn" = "up" ]; then
      vpn_color=',"color":"#FF6600"'  # orange
  else
      vpn_color=',"color":"#00FF00"'  # green
  fi

  # Layout color
  if [ -n "$(missing_color "$layout")" ]; then
      layout_color=$(missing_color "$layout")
  elif [ "$layout" = "en" ]; then
      layout_color=',"color":"#00FF00"'  # green
  else
      layout_color=',"color":"#FFFF00"'  # yellow
  fi

  # Power watts color
  power_num=$(echo "$power_watts" | grep -oP '[\d.]+' | head -1)
  if [ -n "$power_num" ]; then
      if awk "BEGIN {exit !($power_num < 10)}"; then
          power_color=',"color":"#00FF00"'  # green - low power
      elif awk "BEGIN {exit !($power_num < 30)}"; then
          power_color=',"color":"#FFFF00"'  # yellow - medium power
      else
          power_color=',"color":"#FF6600"'  # orange - high power
      fi
  else
      power_color=""
  fi

  # CPU usage color
  cpu_usage_num=$(echo "$cpu_usage" | grep -oP '\d+')
  if [ "$cpu_usage_num" -gt 90 ] 2>/dev/null; then
      cpu_usage_color=',"color":"#FF0000"'  # red - critical
  elif [ "$cpu_usage_num" -gt 70 ] 2>/dev/null; then
      cpu_usage_color=',"color":"#FF6600"'  # orange - high
  elif [ "$cpu_usage_num" -gt 50 ] 2>/dev/null; then
      cpu_usage_color=',"color":"#FFFF00"'  # yellow - medium
  else
      cpu_usage_color=',"color":"#00FF00"'  # green - normal
  fi

  # RAM usage color
  ram_usage_num=$(echo "$ram_usage" | grep -oP '\d+')
  if [ "$ram_usage_num" -gt 90 ] 2>/dev/null; then
      ram_usage_color=',"color":"#FF0000"'  # red - critical
  elif [ "$ram_usage_num" -gt 70 ] 2>/dev/null; then
      ram_usage_color=',"color":"#FF6600"'  # orange - high
  elif [ "$ram_usage_num" -gt 50 ] 2>/dev/null; then
      ram_usage_color=',"color":"#FFFF00"'  # yellow - medium
  else
      ram_usage_color=',"color":"#00FF00"'  # green - normal
  fi

  echo ",[
    {\"full_text\":\"cpu: \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$cpu_temp\"$cpu_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$cpu_usage\"$cpu_usage_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$top_process\",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" | ram: \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$ram_usage\"$ram_usage_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$top_ram_process\",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" | wifi: \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$wifi\"$wifi_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" | vpn: \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$vpn\"$vpn_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" | bt: \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$bluetooth\"$bluetooth_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$bluetooth_battery\"$bt_bat_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" | dns: \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$dns$dns_suffix\"$dns_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" | volume: \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$volume\"$volume_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" | brightness: \",\"separator\":false,\"separator_block_width\":0},
    {\"name\":\"brightness\",\"full_text\":\"$brightness\",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" | \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$capacity\"$capacity_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$status\"$status_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$power_watts\"$power_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" | \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$layout\"$layout_color,\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\" | \",\"separator\":false,\"separator_block_width\":0},
    {\"full_text\":\"$timedate\"}
  ]"
  sleep 0.2
done
}

output_status &
output_pid=$!

trap 'kill "$output_pid" 2>/dev/null' EXIT INT TERM
handle_clicks
wait "$output_pid"
